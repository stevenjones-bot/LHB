      "type": "n8n-nodes-base.xml",
      "typeVersion": 1,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst jobUrls = new Set();\n\nitems.forEach(item => {\n  const data = item.json;\n  \n  if (data.urlset && data.urlset.url) {\n    const urls = Array.isArray(data.urlset.url) ? data.urlset.url : [data.urlset.url];\n    \n    urls.forEach(urlEntry => {\n      if (urlEntry && urlEntry.loc) {\n        const url = urlEntry.loc;\n        if (url.includes('/jobs/') && !jobUrls.has(url)) {\n          jobUrls.add(url);\n        }\n      }\n    });\n  }\n});\n\nreturn Array.from(jobUrls).map(url => ({\n  json: { url }\n}));"
      },
      "id": "code-extract-urls",
      "name": "Code - Extract URLs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
