        },
        "prompt": "Analyze this job posting for Enterprise Account Executive with APAC requirements.\n\nJob URL: {{ $json.url }}\nJob Content: {{ $json.data }}\n\nReturn ONLY JSON:\n{\n  \"url\": \"{{ $json.url }}\",\n  \"match_enterprise_ae\": true/false,\n  \"match_apac\": true/false,\n  \"title_evidence\": \"short quote matching enterprise criteria\",\n  \"apac_evidence\": \"short quote matching APAC criteria\"\n}"
      },
